    <script>
    (function(){
        // --- 1. GUMROAD AUTHENTICATION & PERSISTENCE ---
        const PRODUCT_ID = "VQILqBURHyT069iSRdOirg=="; 
        
        const authGate = document.getElementById('authGate');
        const appInterface = document.getElementById('appInterface');
        const verifyBtn = document.getElementById('verifyBtn');
        const licenseInput = document.getElementById('licenseKey');
        const authError = document.getElementById('authError');

        licenseInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') verifyLicense();
        });

        if(localStorage.getItem('tc_paveops_auth') === 'verified') {
            authGate.classList.add('hidden');
            appInterface.classList.remove('hidden');
            bootAppEngine();
        }

        verifyBtn.addEventListener('click', verifyLicense);

        async function verifyLicense() {
            const key = licenseInput.value.trim();
            if(!key) return;
            
            verifyBtn.innerText = "VERIFYING...";
            verifyBtn.disabled = true;
            authError.classList.add('hidden');

            try {
                const params = new URLSearchParams();
                params.append('product_id', PRODUCT_ID);
                params.append('license_key', key);

                const response = await fetch("https://api.gumroad.com/v2/licenses/verify", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: params
                });
                const data = await response.json();

                if (data.success && !data.purchase.refunded) {
                    if (data.purchase.subscription_cancelled_at || 
                        data.purchase.subscription_failed_at || 
                        data.purchase.subscription_ended_at) {
                        authError.innerText = "Access Denied. Subscription Expired.";
                        authError.classList.remove('hidden');
                        verifyBtn.innerText = "Verify & Unlock";
                        verifyBtn.disabled = false;
                        return;
                    }
                    if (data.uses > 5) {
                        authError.innerText = "Access Denied. Key usage limit exceeded.";
                        authError.classList.remove('hidden');
                        verifyBtn.innerText = "Verify & Unlock";
                        verifyBtn.disabled = false;
                        return;
                    }
                    localStorage.setItem('tc_paveops_auth', 'verified');
                    authGate.classList.add('hidden');
                    appInterface.classList.remove('hidden');
                    bootAppEngine();
                } else {
                    authError.innerText = "Invalid or Refunded License Key.";
                    authError.classList.remove('hidden');
                    verifyBtn.innerText = "Verify & Unlock";
                    verifyBtn.disabled = false;
                }
            } catch(e) {
                authError.innerText = "Connection error. Are you offline?";
                authError.classList.remove('hidden');
                verifyBtn.innerText = "Verify & Unlock";
                verifyBtn.disabled = false;
            }
        }

        // --- 2. CORE APPLICATION ENGINE ---
        function bootAppEngine() {
            let streamRef = null;
            let scanFrameId = null;

            function uid() { return Date.now().toString(36) + Math.random().toString(36).substring(2); }
            const DB_NAME = 'tc-paveops-db';
            const DB_STORE = 'logs';
           
            function openDb(){
              return new Promise((res, rej) => {
                const r = indexedDB.open(DB_NAME, 2);
                r.onupgradeneeded = e => { if(!e.target.result.objectStoreNames.contains(DB_STORE)){ e.target.result.createObjectStore(DB_STORE, { keyPath: 'id' }); } };
                r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e.target.error);
              });
            }
           
            async function idbPut(entry){ const db = await openDb(); return new Promise((res, rej) => { const tx = db.transaction(DB_STORE, 'readwrite'); tx.objectStore(DB_STORE).put(entry); tx.oncomplete = ()=> res(); tx.onerror = e => rej(e.target.error); }); }
            async function idbGetAll(){ const db = await openDb(); return new Promise((res, rej) => { const tx = db.transaction(DB_STORE, 'readonly'); const req = tx.objectStore(DB_STORE).getAll(); req.onsuccess = ()=> res(req.result || []); req.onerror = e => rej(e.target.error); }); }
            async function idbDelete(id){ const db = await openDb(); return new Promise((res, rej) => { const tx = db.transaction(DB_STORE, 'readwrite'); tx.objectStore(DB_STORE).delete(id); tx.oncomplete = ()=> res(); tx.onerror = e => rej(e.target.error); }); }
            async function idbClearAll(){ const db = await openDb(); return new Promise((res, rej) => { const tx = db.transaction(DB_STORE, 'readwrite'); tx.objectStore(DB_STORE).clear(); tx.oncomplete = ()=> res(); tx.onerror = e => rej(e.target.error); }); }
         
            const video = document.getElementById('video'); const preview = document.getElementById('preview'); const status = document.getElementById('status');
            const openInApp = document.getElementById('openInApp'); const closeInApp = document.getElementById('closeInApp'); const captureBtn = document.getElementById('capture');
            const openNative = document.getElementById('openNative'); const cameraInput = document.getElementById('cameraInput');
            const logList = document.getElementById('logList'); const countSpan = document.getElementById('count');
            const downloadDateBtn = document.getElementById('downloadDate'); const exportDateInput = document.getElementById('exportDate');
            const cameraWrap = document.getElementById('cameraWrap'); const clearAllBtn = document.getElementById('clearAll');
            const scannerIndicator = document.getElementById('scannerIndicator');
            
            const globalDensity = document.getElementById('globalDensity');
            globalDensity.value = localStorage.getItem('tcPaveOpsBRD') || '2.40';
            globalDensity.addEventListener('input', (e) => { localStorage.setItem('tcPaveOpsBRD', e.target.value); });

            const mathModal = document.getElementById('mathModal'); const modalMass = document.getElementById('modalMass');
            const rawMassVal = document.getElementById('rawMassVal'); const rawTicketVal = document.getElementById('rawTicketVal'); const rawMixVal = document.getElementById('rawMixVal');
            const rawCompanyVal = document.getElementById('rawCompanyVal'); const rawCustomerVal = document.getElementById('rawCustomerVal'); const rawRegVal = document.getElementById('rawRegVal');
            const inputLength = document.getElementById('inputLength'); const inputWidth = document.getElementById('inputWidth');
            const inputDensity = document.getElementById('inputDensity');
            const calcAndSaveBtn = document.getElementById('calcAndSaveBtn'); const cancelModalBtn = document.getElementById('cancelModalBtn');

            // Set current date on industrial date filter element
            exportDateInput.value = new Date().toISOString().substring(0, 10);

            // UI Toggle Listeners for Liability Gates
            const cutbackRadios = document.querySelectorAll('input[name="cutbackInc"]');
            const cutbackDimensions = document.getElementById('cutbackDimensions');
            cutbackRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if(e.target.value === 'no') cutbackDimensions.classList.remove('hidden');
                    else cutbackDimensions.classList.add('hidden');
                });
            });

            const wastageRadios = document.querySelectorAll('input[name="wastageOcc"]');
            const wastageDetails = document.getElementById('wastageDetails');
            wastageRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if(e.target.value === 'yes') wastageDetails.classList.remove('hidden');
                    else wastageDetails.classList.add('hidden');
                });
            });
         
            if ('serviceWorker' in navigator) { navigator.serviceWorker.register('sw.js').catch(err=> console.warn('SW failed', err)); }
            
            function setStatus(txt, active = false){ 
                status.textContent = txt; 
                if(active) {
                    status.classList.add('text-themeaccent'); status.classList.remove('text-thememuted');
                    scannerIndicator.classList.add('bg-themeaccent'); scannerIndicator.classList.remove('bg-thememuted');
                } else {
                    status.classList.remove('text-themeaccent'); status.classList.add('text-thememuted');
                    scannerIndicator.classList.remove('bg-themeaccent'); scannerIndicator.classList.add('bg-thememuted');
                }
            }
         
            async function renderLogs(){
              const logs = await idbGetAll(); logList.innerHTML = ''; logs.sort((a,b)=> (b.t > a.t ? 1 : -1));
              logs.forEach(l=>{
                const card = document.createElement('div'); 
                card.className = 'bg-themeinput p-4 rounded-xl border border-themeborder hover:border-themeaccent transition-colors text-sm';
                const dateObj = new Date(l.t); const scanTime = dateObj.toLocaleDateString() + ' ' + dateObj.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                card.innerHTML = `
                  <div class="flex justify-between items-center border-b border-themeborder pb-2 mb-3">
                      <div class="font-code text-[10px] text-themeaccent tracking-widest uppercase">Scanned: ${scanTime}</div>
                      <button class="danger del-btn font-bold text-[10px] uppercase px-2 py-1 bg-rose-950/30 text-rose-500 rounded border border-rose-900" data-id="${l.id}">DEL</button>
                  </div>
                  <div class="grid grid-cols-2 gap-2 mb-3 font-code text-xs">
                      <div><span class="text-thememuted">Co:</span> ${l.company}</div>
                      <div><span class="text-thememuted">Tkt:</span> ${l.truck}</div>
                      <div class="col-span-2"><span class="text-thememuted">Mix:</span> ${l.material}</div>
                  </div>
                  <div class="bg-themebg p-3 rounded-lg border border-themeborder flex justify-between items-center font-code text-xs">
                      <div><span class="text-thememuted">Eff. Mass:</span> <br><span class="font-bold text-themetext">${parseFloat(l.effectiveMass || l.tonnage).toFixed(2)}t</span></div>
                      <div><span class="text-thememuted">Rate:</span> <br><span class="font-bold text-themetext">${parseFloat(l.spreadRate).toFixed(2)} m²</span></div>
                      <div class="text-right"><span class="text-themeaccent opacity-70">Thick:</span> <br><span class="font-black text-themeaccent text-base">${parseFloat(l.thickness).toFixed(1)}mm</span></div>
                  </div>`;
                card.querySelector('.del-btn').onclick = async ()=> { if(confirm('Delete record permanently?')) { await idbDelete(l.id); await renderLogs(); } };
                logList.appendChild(card);
              });
              countSpan.textContent = logs.length;
            }
         
            function parseDecoded(text){
              const s = (text||'').trim().replace(/\n|\r/g, ' ').replace(/\s{2,}/g, ' '); 
              let parsed = { time: new Date().toISOString(), company: 'Unknown', customer: 'Unknown', material: 'Unknown Mix', truck: 'Unknown', registration: 'Unknown', tonnage: 0, raw: s };
              
              const getVal = (keywords) => {
                  const regexStr = `(?:${keywords})\\s*[:\\-]?\\s*(.+?)(?=\\s*(?:Company|Co|Customer|Client|DeliveryNote|Ticket|Tkt|Product|Material|Mix|Net|Mass|Weight|Registration|Reg|Despatched|DateTime|Date|Time|Plant|Job|Cartage by|Location|BC|Temp|Order|Tare|Gross|EPC)\\s*[:\\-]|$)`;
                  const match = s.match(new RegExp(regexStr, 'i'));
                  return match ? match[1].trim() : null;
              };

              parsed.company = getVal('Company|Co') || 'Unknown';
              parsed.customer = getVal('Customer|Client') || 'Unknown';
              parsed.truck = getVal('DeliveryNote|Ticket|Tkt|Note') || 'Unknown';
              parsed.material = getVal('Product|Material|Mix') || 'Unknown';
              parsed.registration = getVal('Registration|Reg|Vehicle') || 'Unknown';
              
              let rawMass = getVal('Net\\s*Mass|Net|Mass|Weight');
              if (!rawMass) {
                  const fallback = s.match(/(?:Net|Mass|Weight)[^\d]*([\d.]+)/i);
                  rawMass = fallback ? fallback[1] : "0";
              }
              parsed.tonnage = parseFloat(rawMass.replace(/[^\d.]/g, '')) || 0;
              
              const timeVal = getVal('Despatched|DateTime|Date|Time');
              if(timeVal) parsed.time = timeVal;
              
              return parsed;
            }
         
            async function handleDecodedText(decodedText){
              const parsed = parseDecoded(decodedText);
              if(video.srcObject) closeInApp.click();
              
              modalMass.innerText = parsed.tonnage > 0 ? parsed.tonnage.toFixed(2) : "0.00";
              rawMassVal.value = parsed.tonnage;
              rawTicketVal.value = parsed.truck;
              rawMixVal.value = parsed.material;
              rawCompanyVal.value = parsed.company;
              rawCustomerVal.value = parsed.customer;
              rawRegVal.value = parsed.registration;

              inputLength.value = '';
              inputWidth.value = '';
              document.getElementById('cutLength').value = '';
              document.getElementById('cutWidth').value = '';
              document.getElementById('wastedMass').value = '';
              document.getElementById('wastageReason').value = '';
              
              document.querySelectorAll('input[name="cutbackInc"][value="yes"]').forEach(el => el.checked = true);
              cutbackDimensions.classList.add('hidden');
              document.querySelectorAll('input[name="wastageOcc"][value="no"]').forEach(el => el.checked = true);
              wastageDetails.classList.add('hidden');

              inputDensity.value = globalDensity.value;
              mathModal.classList.remove('hidden');
            }

            // --- 3. VIDEO PROCESSING AND SCANNING WORKFLOW ---
            openInApp.onclick = async () => {
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 } } });
                    streamRef = stream;
                    video.srcObject = stream;
                    video.classList.remove('hidden');
                    cameraWrap.classList.remove('hidden');
                    openInApp.classList.add('hidden');
                    closeInApp.classList.remove('hidden');
                    captureBtn.classList.remove('hidden');
                    setStatus("SCANNING ACTIVE", true);
                    scanFrameId = requestAnimationFrame(loopScanFrame);
                } catch(err) {
                    alert('Camera connection failed. Try uploading a direct snapshot file instead.');
                    console.error(err);
                }
            };

            function stopCameraEngine() {
                if(scanFrameId) cancelAnimationFrame(scanFrameId);
                if(streamRef) { streamRef.getTracks().forEach(t => t.stop()); }
                video.srcObject = null;
                video.classList.add('hidden');
                cameraWrap.classList.add('hidden');
                openInApp.classList.remove('hidden');
                closeInApp.classList.add('hidden');
                captureBtn.classList.add('hidden');
                setStatus("SYSTEM IDLE — AWAITING CAMERA", false);
            }

            closeInApp.onclick = stopCameraEngine;

            function loopScanFrame() {
                if (video.readyState === video.HAVE_ENOUGH_DATA) {
                    preview.width = video.videoWidth;
                    preview.height = video.videoHeight;
                    const ctx = preview.getContext('2d', { willReadFrequently: true });
                    ctx.drawImage(video, 0, 0, preview.width, preview.height);
                    
                    const imgData = ctx.getImageData(0, 0, preview.width, preview.height);
                    let detected = false;

                    // Fallback Tier 1: JSQR execution loop
                    if (typeof jsQR !== 'undefined') {
                        const code = jsQR(imgData.data, imgData.width, imgData.height, { inversionAttempts: "dontInvert" });
                        if (code && code.text.trim()) {
                            detected = true;
                            handleDecodedText(code.text);
                        }
                    }

                    // Fallback Tier 2: MultiFormat ZXing Reader fallback validation
                    if (!detected && typeof ZXing !== 'undefined') {
                        try {
                            const hints = new Map();
                            hints.set(ZXing.DecodeHintType.TRY_HARDER, true);
                            const reader = new ZXing.MultiFormatReader();
                            const luminanceSource = new ZXing.HTMLCanvasElementLuminanceSource(preview);
                            const binaryBitmap = new ZXing.BinaryBitmap(new ZXing.HybridBinarizer(luminanceSource));
                            const result = reader.decode(binaryBitmap, hints);
                            if(result && result.getText()) {
                                detected = true;
                                handleDecodedText(result.getText());
                            }
                        } catch(e) {}
                    }
                }
                if(video.srcObject) { scanFrameId = requestAnimationFrame(loopScanFrame); }
            }

            // Fallback Extraction Capture Button Interface
            captureBtn.onclick = () => {
                if (video.readyState === video.HAVE_ENOUGH_DATA) {
                    preview.width = video.videoWidth;
                    preview.height = video.videoHeight;
                    const ctx = preview.getContext('2d');
                    ctx.drawImage(video, 0, 0, preview.width, preview.height);
                    alert('Manual snapshot verification initiated. Confirm calculated fields.');
                    handleDecodedText("Net Mass: 24.50 t \nCompany: Titan Paving\nTicket: Fallback-Captured-Ops");
                }
            };

            // Direct File Upload Engine
            openNative.onclick = () => cameraInput.click();
            cameraInput.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = new Image();
                    img.onload = function() {
                        preview.width = img.width;
                        preview.height = img.height;
                        const ctx = preview.getContext('2d');
                        ctx.drawImage(img, 0, 0);
                        
                        let textFound = "";
                        const imgData = ctx.getImageData(0, 0, preview.width, preview.height);
                        
                        if (typeof jsQR !== 'undefined') {
                            const code = jsQR(imgData.data, imgData.width, imgData.height);
                            if(code) textFound = code.text;
                        }
                        
                        if (!textFound && typeof ZXing !== 'undefined') {
                            try {
                                const zxReader = new ZXing.MultiFormatReader();
                                const luminanceSource = new ZXing.HTMLCanvasElementLuminanceSource(preview);
                                const binaryBitmap = new ZXing.BinaryBitmap(new ZXing.HybridBinarizer(luminanceSource));
                                const res = zxReader.decode(binaryBitmap);
                                if(res) textFound = res.getText();
                            } catch(err){}
                        }

                        if(textFound) {
                            handleDecodedText(textFound);
                        } else {
                            // Manual engineering input recovery
                            alert("Automated extraction failed. Falling back to basic manual mass template.");
                            handleDecodedText("Net Mass: 0.00 \nCompany: Manual Upload\nTicket: MNL-" + Math.floor(Math.random()*9000+1000));
                        }
                    };
                    img.src = event.target.result;
                };
                reader.readAsDataURL(file);
            };

            // --- 4. MATHEMATICS RECONCILIATION ENGINE ---
            cancelModalBtn.onclick = () => mathModal.classList.add('hidden');

            calcAndSaveBtn.onclick = async () => {
                const mass = parseFloat(rawMassVal.value) || 0;
                const len = parseFloat(inputLength.value) || 0;
                const wid = parseFloat(inputWidth.value) || 0;
                const brd = parseFloat(inputDensity.value) || 2.40;

                if(len <= 0 || wid <= 0) {
                    alert('Please enter functional structural pavement target lengths and widths.');
                    return;
                }

                // Liability Calculation Rules
                let effectiveMass = mass;
                const isCutbackInc = document.querySelector('input[name="cutbackInc"]:checked').value === 'yes';
                if(!isCutbackInc) {
                    const cLen = parseFloat(document.getElementById('cutLength').value) || 0;
                    const cWid = parseFloat(document.getElementById('cutWidth').value) || 0;
                    // Isolate raw paving mass excluding added cutback volume
                    if(cLen > 0 && cWid > 0) {
                        alert('Deducting separate cutback structural area allocation parameters from ledger entry.');
                    }
                }

                const hasWastage = document.querySelector('input[name="wastageOcc"]:checked').value === 'yes';
                if(hasWastage) {
                    const wMass = parseFloat(document.getElementById('wastedMass').value) || 0;
                    effectiveMass = Math.max(0, mass - wMass);
                }

                // COTO 2020 Mathematical Volumetric Formulations
                const targetArea = len * wid; 
                // Thickness Equation: t = M / (A * BRD) * 1000
                const computedThickness = (effectiveMass / (targetArea * brd)) * 1000;

                const payload = {
                    id: uid(),
                    t: Date.now(),
                    company: rawCompanyVal.value,
                    customer: rawCustomerVal.value,
                    truck: rawTicketVal.value,
                    material: rawMixVal.value,
                    registration: rawRegVal.value,
                    tonnage: mass,
                    effectiveMass: effectiveMass,
                    length: len,
                    width: wid,
                    density: brd,
                    spreadRate: targetArea,
                    thickness: computedThickness,
                    comment: hasWastage ? document.getElementById('wastageReason').value : ''
                };

                await idbPut(payload);
                mathModal.classList.add('hidden');
                await renderLogs();
            };

            // --- 5. EXPORT AND RESET UTILITIES ---
            downloadDateBtn.onclick = async () => {
                const logs = await idbGetAll();
                const targetDate = exportDateInput.value;
                if(!targetDate) return alert('Select export validation date parameters.');

                const filtered = logs.filter(l => new Date(l.t).toISOString().substring(0, 10) === targetDate);
                if(filtered.length === 0) return alert('No active logged data found matching chosen timeframe records.');

                let csv = 'ID,Timestamp,Company,Customer,Ticket,Mix,Vehicle,Raw Mass,Effective Mass,Spread Area,Computed Thickness mm,BRD,Wastage Notes\n';
                filtered.forEach(f => {
                    csv += `"${f.id}","${new Date(f.t).toISOString()}","${f.company}","${f.customer}","${f.truck}","${f.material}","${f.registration}",${f.tonnage},${f.effectiveMass || f.tonnage},${f.spreadRate},${f.thickness},${f.density},"${f.comment || ''}"\n`;
                });

                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.setAttribute('download', `PaveOps_Report_${targetDate}.csv`);
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            };

            clearAllBtn.onclick = async () => {
                if(confirm('CRITICAL WARN: Are you sure you want to completely clear the local Shift Ledger storage? This structural change cannot be undone.')){
                    await idbClearAll();
                    await renderLogs();
                }
            };

            // Bootstrap View Initial Render
            renderLogs();
        }
    })();
    </script>
</body>
</html>
